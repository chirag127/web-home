---
/*
 * AppSidebarContent — per-app slot child for the family mega-nav.
 * Renders inside @chirag127/astro-chrome/Sidebar.astro's default slot.
 *
 * Uses the FAMILY_SITES catalog from @chirag127/astro-data and the local
 * APPS list. Lazy: links only, no fancy state.
 */
import { FAMILY_SITES } from '~/lib/family'
import { APPS } from '~/data/apps'

const hub = [{ href: 'https://oriz.in/', label: 'Home' }]
const content = APPS.filter((a) => a.category === 'content').map((a) => ({ href: a.subdomain, label: a.brand }))
const tools = APPS.filter((a) => a.category === 'tool').map((a) => ({ href: a.subdomain, label: a.brand }))
const personal = APPS.filter((a) => a.category === 'personal').map((a) => ({ href: a.subdomain, label: a.brand }))
const books = FAMILY_SITES.filter((s) => s.category === 'reading').map((s) => ({ href: s.url, label: s.name }))

const groups = [
  { label: 'Hub', items: hub },
  { label: 'Apps · Content', items: content },
  { label: 'Apps · Tools', items: tools },
  { label: 'Apps · Personal', items: personal },
  { label: 'Books', items: books },
]
---
{groups.map((g) => (
  <section class="sb-group">
    <h3>{g.label}</h3>
    <ul>
      {g.items.map((i) => (
        <li><a href={i.href}>{i.label}</a></li>
      ))}
    </ul>
  </section>
))}

<style>
  .sb-group { margin-bottom: 1rem; }
  .sb-group h3 {
    font-family: var(--font-mono, monospace);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-mute);
    margin: 0 0 0.375rem;
  }
  .sb-group ul { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 2px; }
  .sb-group a {
    display: block;
    padding: 4px 6px;
    font-size: 13px;
    color: var(--ink);
    text-decoration: none;
    border-radius: 3px;
  }
  .sb-group a:hover { background: color-mix(in oklab, var(--mustard) 14%, transparent); color: var(--mustard); }
</style>
