---
/*
 * Header — v0 locked design 2026-06-22.
 *
 * Sticky paper background w/ vermilion underline accent. Wordmark "oriz"
 * (Fraunces). Nav: Apps · Tools · Books · Packages · About. Support chip
 * on the right. Mobile: nav collapses; hamburger toggles the family
 * sidebar drawer.
 */
---

<header class="hdr">
  <div class="spine hdr-row">
    <a class="hdr-wm" href="/" aria-label="oriz home">
      <span class="hdr-wm-letter">o</span><span class="hdr-wm-letter">r</span><span
        class="hdr-wm-letter">i</span><span class="hdr-wm-letter hdr-wm-z">z</span>
    </a>

    <nav class="hdr-nav" aria-label="Primary">
      <a href="/apps/">Apps</a>
      <a href="/tools/">Tools</a>
      <a href="/books/">Books</a>
      <a href="/packages/">Packages</a>
      <a href="/about/">About</a>
    </nav>

    <div class="hdr-right">
      <a href="/support/" class="hdr-signin">Support</a>
      <button
        class="hdr-burger"
        type="button"
        aria-label="Open menu"
        aria-expanded="false"
        data-hdr-burger
      >
        <span aria-hidden="true">☰</span>
      </button>
    </div>
  </div>
</header>

<style>
  .hdr {
    position: sticky;
    top: 0;
    z-index: 40;
    background: color-mix(in oklab, var(--color-bg) 92%, transparent);
    backdrop-filter: saturate(140%) blur(8px);
    -webkit-backdrop-filter: saturate(140%) blur(8px);
    border-bottom: 1px solid var(--color-border);
  }
  .hdr-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    height: 64px;
  }
  .hdr-wm {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1;
    color: var(--color-fg);
    text-decoration: none;
    display: inline-flex;
    align-items: baseline;
    padding-block: 0.25rem;
    border-bottom: 2px solid transparent;
    transition: border-color 0.18s;
  }
  .hdr-wm:hover {
    border-bottom-color: var(--color-accent);
  }
  .hdr-wm-letter {
    display: inline-block;
  }
  .hdr-wm-z {
    color: var(--color-accent);
  }

  .hdr-nav {
    display: flex;
    gap: 1.25rem;
    margin-left: 1rem;
  }
  .hdr-nav a {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--color-fg);
    text-decoration: none;
    padding-block: 0.25rem;
    border-bottom: 2px solid transparent;
    transition: border-color 0.18s, color 0.18s;
  }
  .hdr-nav a:hover,
  .hdr-nav a:focus-visible {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
    outline: none;
  }

  .hdr-right {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .hdr-signin {
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-bg);
    background: var(--color-fg);
    padding: 0.5rem 0.875rem;
    border-radius: 999px;
    text-decoration: none;
    border: 1px solid var(--color-fg);
    transition: background 0.18s, color 0.18s;
  }
  .hdr-signin:hover {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: #fff;
  }

  .hdr-burger {
    display: none;
    background: transparent;
    border: 1px solid var(--color-border);
    color: var(--color-fg);
    width: 40px;
    height: 40px;
    border-radius: 8px;
    font-size: 1.125rem;
    cursor: pointer;
  }
  .hdr-burger:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  @media (max-width: 768px) {
    .hdr-nav {
      display: none;
    }
    .hdr-burger {
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }
    .hdr-signin {
      padding: 0.375rem 0.75rem;
      font-size: 0.8125rem;
    }
  }
</style>

<script>
  /* Burger toggles the chrome Sidebar drawer if one's mounted; otherwise
     it falls back to anchoring at #sb-toggle (matches BottomBar menu). */
  const btn = document.querySelector<HTMLButtonElement>('[data-hdr-burger]')
  btn?.addEventListener('click', () => {
    const drawer = document.querySelector<HTMLInputElement>('#sb-toggle')
    if (drawer && 'checked' in drawer) {
      drawer.checked = !drawer.checked
      btn.setAttribute('aria-expanded', String(drawer.checked))
      return
    }
    // Fallback: scroll to sidebar anchor.
    const sb = document.getElementById('sb-toggle')
    if (sb) sb.scrollIntoView({ behavior: 'smooth' })
  })
</script>
