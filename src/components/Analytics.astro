---
interface Props {
  cf?: string // Cloudflare Web Analytics token (free, no card, no cookies)
  clarity?: string // Microsoft Clarity project ID (free, heatmaps + recordings)
  posthog?: string // PostHog API key (free: 1M events/mo)
  posthogHost?: string // PostHog host (default: us.i.posthog.com)
  ga?: string // Google Analytics 4 measurement ID (G-XXXXXXXXXX, free)
  sentry?: string // Sentry DSN (free for OSS via sentry.io/for/open-source/)
  sentryRelease?: string
  plausible?: string // Plausible domain (free for OSS via plausible.io/open-source/)
}
const {
  cf,
  clarity,
  posthog,
  posthogHost = 'https://us.i.posthog.com',
  ga,
  sentry,
  sentryRelease,
  plausible,
} = Astro.props
---

{/* Cloudflare Web Analytics — free, no cookies, GDPR-safe */}
{cf && <script defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon={JSON.stringify({token:cf})}></script>}

{/* Microsoft Clarity — free, session replay + heatmaps */}
{clarity && <script set:html={`(function(c,l,a,r,i,t,y){c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y)})(window,document,"clarity","script","${clarity}")`}></script>}

{/* PostHog — free: 1M events/mo, product analytics + session replay */}
{posthog && <script set:html={`!function(t,e){var o,n,p,r;e.__SV||(window.posthog=e,e._i=[],e.init=function(i,s,a){function g(t,e){var o=e.split(".");2==o.length&&(t=t[o[0]],e=o[1]),t[e]=function(){t.push([e].concat(Array.prototype.slice.call(arguments,0)))}}(p=t.createElement("script")).type="text/javascript",p.async=!0,p.src=s.api_host+"/static/array.js",(r=t.getElementsByTagName("script")[0]).parentNode.insertBefore(p,r);var u=e;for(void 0!==a?u=e[a]=[]:a="posthog",u.people=u.people||[],u.toString=function(t){var e="posthog";return"posthog"!==a&&(e+="."+a),t||(e+=" (stub)"),e},u.people.toString=function(){return u.toString(1)+" (stub)"},o="capture identify alias people.set people.set_once set_config register register_once unregister opt_out_capturing has_opted_out_capturing opt_in_capturing reset isFeatureEnabled onFeatureFlags getFeatureFlag getFeatureFlagPayload reloadFeatureFlags group updateEarlyAccessFeatureEnrollment getEarlyAccessFeatures getActiveMatchingSurveys getSurveys".split(" "),n=0;n<o.length;n++)g(u,o[n]);e._i.push([i,s,a])},e.__SV=1)}(document,window.posthog||[]);posthog.init("${posthog}",{api_host:"${posthogHost}",person_profiles:"identified_only"})`}></script>}

{/* Google Analytics 4 — free, universal, anonymized IP */}
{ga && <script async src={`https://www.googletagmanager.com/gtag/js?id=${ga}`}></script>}
{ga && <script set:html={`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments)}gtag('js',new Date());gtag('config','${ga}',{anonymize_ip:true,cookie_flags:'SameSite=None;Secure'})`}></script>}

{/* Sentry — free for OSS (apply at sentry.io/for/open-source/), error monitoring + performance */}
{sentry && <script set:html={`
(function(){
  var s=document.createElement('script');
  s.src='https://browser.sentry-cdn.com/8.x/bundle.tracing.min.js';
  s.crossOrigin='anonymous';
  s.onload=function(){
    if(typeof Sentry==='undefined')return;
    Sentry.init({
      dsn:'${sentry}',
      ${sentryRelease ? `release:'${sentryRelease}',` : ''}
      tracesSampleRate:0.1,
      replaysOnErrorSampleRate:1.0,
    });
  };
  document.head.appendChild(s);
})();
`}></script>}

{/* Plausible — free for OSS (apply at plausible.io/open-source-website-analytics), no cookies */}
{plausible && <script defer data-domain={plausible} src="https://plausible.io/js/script.js"></script>}
