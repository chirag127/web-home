---
/*
 * ChannelBadge.astro — small inline button used by AppCard.
 *
 * Two modes:
 *   1. Live — given a URL, render an <a> linking to the store / download.
 *   2. Coming soon — given a missing URL, render a muted <span> with a
 *      "Coming soon" label. Per knowledge/decisions/architecture/
 *      pwabuilder-as-primary-converter.md, the copy hints that native
 *      packages come via PWABuilder.
 *
 * Channels share visual treatment (mono-cap label + 12-px icon) so the
 * page reads as a uniform grid of badges, not a Brand-Asset Avenger pile.
 */
import type { Channel } from '~/data/apps'

interface Props {
  channel: Channel
  url?: string | undefined
  /** Override the default label — useful for "Coming soon — Android via PWABuilder". */
  comingSoonLabel?: string
}

const { channel, url, comingSoonLabel } = Astro.props

/* Per-channel display config. */
const LABELS: Record<Channel, string> = {
  web: 'Open web',
  pwa: 'Install PWA',
  play_store: 'Play Store',
  ms_store: 'Microsoft Store',
  cws: 'Chrome Web Store',
  firefox: 'Firefox Add-ons',
  edge: 'Edge Add-ons',
  vsce: 'VS Code Marketplace',
  open_vsx: 'Open VSX',
  github_release_apk: 'APK (sideload)',
  github_release_msix: 'MSIX (direct)',
  github_release_dmg: 'macOS .dmg',
  github_release_appimage: 'Linux AppImage',
}

/* Tiny single-glyph emoji-free icon set — we use lucide via inline SVG
 * paths to avoid a React island per badge. (lucide-react is already a
 * dep — but this is server-rendered and we want zero hydration cost.) */
const ICONS: Record<Channel, string> = {
  // Globe
  web: 'M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20Zm0 0c2.5 2.5 4 6 4 10s-1.5 7.5-4 10m0-20c-2.5 2.5-4 6-4 10s1.5 7.5 4 10M2 12h20',
  // Smartphone
  pwa: 'M5 2h14a1 1 0 0 1 1 1v18a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V3a1 1 0 0 1 1-1Zm6 16h2',
  // Play (triangle in rounded square)
  play_store: 'M4 4l16 8-16 8V4Z',
  // Square (Microsoft Store quad)
  ms_store: 'M3 3h8v8H3zM13 3h8v8h-8zM3 13h8v8H3zM13 13h8v8h-8z',
  // Chrome (circle + radii)
  cws: 'M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20Zm0 6a4 4 0 1 0 0 8 4 4 0 0 0 0-8Zm0-6v6m-8.5 7L9 12m11.5 5L15 12',
  // Flame (Firefox)
  firefox: 'M12 2c2 4 5 4 5 9a5 5 0 0 1-10 0c0-2 1-3 2-4-1 5 4 6 4 2 0-3-2-4-1-7Z',
  // Box (Edge — abstract)
  edge: 'M3 7l9-5 9 5v10l-9 5-9-5V7Zm9-5v20M3 7l9 5 9-5',
  // Code brackets (VSCE)
  vsce: 'M8 6l-6 6 6 6m8-12l6 6-6 6',
  // Open box (Open VSX)
  open_vsx: 'M3 7l9-4 9 4v10l-9 4-9-4V7Zm0 0l9 4 9-4m-9 4v10',
  // Download (APK direct)
  github_release_apk: 'M12 3v12m0 0l-4-4m4 4l4-4M4 21h16',
  github_release_msix: 'M12 3v12m0 0l-4-4m4 4l4-4M4 21h16',
  github_release_dmg: 'M12 3v12m0 0l-4-4m4 4l4-4M4 21h16',
  github_release_appimage: 'M12 3v12m0 0l-4-4m4 4l4-4M4 21h16',
}

/* Default 'coming soon' subtitles. */
function defaultComingSoon(c: Channel): string {
  if (c === 'play_store' || c === 'github_release_apk')
    return 'Coming soon — Android via PWABuilder'
  if (c === 'ms_store' || c === 'github_release_msix') return 'Coming soon — Windows via PWABuilder'
  if (c === 'github_release_dmg') return 'Coming soon — macOS via PWABuilder'
  if (c === 'github_release_appimage') return 'Coming soon — Linux via PWABuilder'
  if (c === 'cws') return 'Coming soon — Chrome Web Store'
  if (c === 'firefox') return 'Coming soon — Firefox Add-ons'
  if (c === 'edge') return 'Coming soon — Edge Add-ons'
  if (c === 'vsce') return 'Coming soon — VS Code Marketplace'
  if (c === 'open_vsx') return 'Coming soon — Open VSX'
  return 'Coming soon'
}

const label = LABELS[channel]
const icon = ICONS[channel]
const fallbackLabel = comingSoonLabel ?? defaultComingSoon(channel)
---

{
  url ? (
    <a class="badge badge-live" href={url} rel="noopener" data-channel={channel}>
      <svg class="badge-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d={icon} />
      </svg>
      <span class="badge-label">{label}</span>
    </a>
  ) : (
    <span class="badge badge-soon" data-channel={channel}>
      <svg class="badge-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d={icon} />
      </svg>
      <span class="badge-label">{fallbackLabel}</span>
    </span>
  )
}

<style>
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.25rem 0.5rem;
    border: 1px solid var(--rule);
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--ink);
    text-decoration: none;
    border-radius: 0;
    line-height: 1;
    transition: color 100ms, border-color 100ms, background 100ms;
  }
  .badge-live:hover,
  .badge-live:focus-visible {
    color: var(--mustard);
    border-color: var(--mustard);
    outline: none;
  }
  .badge-soon {
    color: var(--ink-mute);
    border-style: dashed;
    cursor: default;
  }
  .badge-icon {
    width: 12px;
    height: 12px;
    flex-shrink: 0;
  }
  .badge-label {
    white-space: nowrap;
  }
</style>
