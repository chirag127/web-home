---
/*
 * Wordmark — `oriz` set in display serif with a vermilion hairline strike
 * through the `z` glyph. The proofreader's deletion mark rendered as the
 * brand mark.
 *
 * This is THE family-anchor brand asset. Sister sites copy this component
 * verbatim and just change the optional `subtitle` prop:
 *   <Wordmark subtitle="blog" />   →  oriz / blog
 *   <Wordmark subtitle="me" />     →  oriz / me
 *   <Wordmark />                   →  oriz (bare)
 *
 * Because the `z` strike must move with the glyph at any size, the strike
 * is rendered as an inline SVG pseudo-rule in absolute positioning, not as
 * a CSS underline (which would not extend past the glyph correctly).
 *
 * Vermilion appears here at FIRST PAINT — this is the one allowed
 * occurrence in the wordmark. The other allowed first-paint vermilion is
 * the lone `start anywhere ↓` arrow on the index page.
 */

interface Props {
  /** Sub-section name — rendered after a `/` separator in mustard. */
  subtitle?: string
  /** Display size in CSS pixels. Defaults to 96 (the masthead lockup size). */
  size?: number
  /** Wrap the mark in an <a href="/"> — defaults true on every page except `/`. */
  href?: string | null
  /** Render-only mode for the masthead (no link wrapper). */
  asHeading?: boolean
}

const { subtitle, size = 96, href = null, asHeading = false } = Astro.props
const Tag = asHeading ? 'h1' : ('div' as const)
---

{
  href ? (
    <a class="wordmark-link" href={href} aria-label={subtitle ? `oriz / ${subtitle}` : 'oriz'}>
      <Tag class="wordmark" style={`--wm-size: ${size}px;`}>
        <span class="wordmark-mark">
          <span class="wordmark-letter">o</span>
          <span class="wordmark-letter">r</span>
          <span class="wordmark-letter">i</span>
          <span class="wordmark-letter wordmark-z">
            z
            <span class="wordmark-strike" aria-hidden="true" />
          </span>
        </span>
        {subtitle && (
          <>
            <span class="wordmark-sep" aria-hidden="true">
              /
            </span>
            <span class="wordmark-sub">{subtitle}</span>
          </>
        )}
      </Tag>
    </a>
  ) : (
    <Tag class="wordmark" style={`--wm-size: ${size}px;`}>
      <span class="wordmark-mark">
        <span class="wordmark-letter">o</span>
        <span class="wordmark-letter">r</span>
        <span class="wordmark-letter">i</span>
        <span class="wordmark-letter wordmark-z">
          z
          <span class="wordmark-strike" aria-hidden="true" />
        </span>
      </span>
      {subtitle && (
        <>
          <span class="wordmark-sep" aria-hidden="true">
            /
          </span>
          <span class="wordmark-sub">{subtitle}</span>
        </>
      )}
    </Tag>
  )
}

<style>
  .wordmark-link {
    display: inline-block;
    color: inherit;
    text-decoration: none;
  }
  .wordmark {
    display: inline-flex;
    align-items: baseline;
    gap: 0.18em;
    margin: 0;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--wm-size, 96px);
    line-height: 1;
    letter-spacing: 0.01em;
    color: var(--ink);
  }
  .wordmark-mark {
    display: inline-flex;
    align-items: baseline;
  }
  .wordmark-letter {
    position: relative;
    display: inline-block;
  }
  .wordmark-z {
    /* The glyph holds the strike — strike must extend 0.15em past on each side. */
    padding-inline: 0.15em;
  }
  .wordmark-strike {
    position: absolute;
    inset: 50% 0 auto 0;
    height: 0.04em;
    background: var(--vermilion);
    transform: translateY(-50%);
    pointer-events: none;
  }
  /* At small sizes the strike rounds to <1px — clamp it. */
  @media (max-width: 480px) {
    .wordmark-strike {
      height: max(1px, 0.04em);
    }
  }
  .wordmark-sep {
    margin-inline: 0.18em 0.18em;
    color: var(--ink-mute);
    font-weight: 400;
  }
  .wordmark-sub {
    color: var(--mustard);
    font-style: italic;
    font-weight: 400;
  }
  /* Light mode — mustard darkens to keep contrast on cream. The token already
     handles this; nothing to do here. */
</style>
