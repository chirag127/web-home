---
/*
 * LatestPackageCard — top-1 from the family npm packages.
 *
 * Reads from the inlined family registry (~/lib/family), picks the
 * astro-analytics entry by default, and renders the card.
 */
import { FAMILY_PACKAGES, type FamilyPackage } from '~/lib/family'

/* Pick astro-analytics as the headline; fall back to the first astro-category entry. */
function pickHeadline(): FamilyPackage {
  return (
    FAMILY_PACKAGES.find((p) => p.slug === 'astro-analytics') ??
    FAMILY_PACKAGES.find((p) => p.category === 'astro') ??
    FAMILY_PACKAGES[0]
  )
}

const pkg = pickHeadline()
const LATEST_PKG = {
  name: pkg.npm,
  short: pkg.slug,
  version: pkg.version ?? '',
  blurb: pkg.tagline ?? 'A package from the chirag127/oriz family.',
  url: `https://npm.im/${pkg.npm}`,
}
---

<article class="fc fc-pkg">
  <header class="fc-h">
    <span class="fc-kicker">Latest package</span>
    <a class="fc-more" href="https://packages.oriz.in">Packages →</a>
  </header>
  <h3 class="fc-title">
    <a href={LATEST_PKG.url}>{LATEST_PKG.short}</a>
    {LATEST_PKG.version && <span class="fc-pkg-v">v{LATEST_PKG.version}</span>}
  </h3>
  <p class="fc-excerpt">{LATEST_PKG.blurb}</p>
  <pre class="fc-pkg-cmd"><code>npm i {LATEST_PKG.name}</code></pre>
</article>

<style>
  .fc-pkg {
    background: #fff;
    border-left: 3px solid var(--color-fg);
  }
  .fc-pkg-v {
    font-family: var(--font-utility);
    font-size: 0.6875rem;
    color: var(--color-muted);
    margin-left: 0.375rem;
    font-weight: 400;
    letter-spacing: 0.02em;
  }
  .fc-pkg-cmd {
    font-family: var(--font-utility);
    font-size: 0.75rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    padding: 0.5rem 0.625rem;
    margin: 0.5rem 0 0;
    overflow-x: auto;
    color: var(--color-fg);
    line-height: 1.4;
  }
  .fc-pkg-cmd code {
    font-family: inherit;
  }
</style>
