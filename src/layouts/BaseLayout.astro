---
/*
 * BaseLayout — single page shell for every oriz-home route.
 *
 * v2 broadsheet almanac. Dark spine. No theme picker (the brief allows a
 * light variant via prefers-color-scheme but nothing user-toggleable).
 *
 * 2026-06-22 revert (sweep #5):
 *   • Header is LOCAL (~/components/Header.astro) — fully divergent per-app.
 *   • Footer/Sidebar/BottomBar STRUCTURE imported from @chirag127/astro-chrome
 *     with per-app slot content (AppSidebarContent + bottomBarActions).
 *   • Footer remains identical mega-sitemap across the family.
 */
import '~/styles/global.css'
import '~/styles/oriz-ui-overrides.css'
import '@chirag127/astro-shell/tokens.css'
import Header from '~/components/Header.astro'
import Sidebar from '@chirag127/astro-chrome/Sidebar.astro'
import Footer from '@chirag127/astro-chrome/Footer.astro'
import BottomBar from '@chirag127/astro-chrome/BottomBar.astro'
import AppSidebarContent from '~/components/AppSidebarContent.astro'
import JsonLd from '~/components/JsonLd.astro'
import ConsentBanner from '@chirag127/astro-chrome/ConsentBanner.astro'
import { FAMILY_SITES } from '~/lib/family'
import { bottomBarActions } from '~/data/bottombar-actions'

interface Props {
  title?: string
  description?: string
  canonical?: string
  noindex?: boolean
  jsonLd?: Record<string, unknown> | Record<string, unknown>[]
  wordmarkSubtitle?: string
  chrome?: 'full' | 'bare'
  bodyClass?: string
}

const {
  title = 'oriz — a family of small, free, static sites by Chirag Singhal',
  description = 'A free family of static sites: book summaries, NCERT directory, India card intelligence, finance calculators, dev tools, blog, and a privacy-first journal.',
  canonical = `https://oriz.in${Astro.url.pathname}`,
  noindex = false,
  jsonLd,
  chrome = 'full',
  bodyClass,
} = Astro.props

const adsenseClient = import.meta.env.PUBLIC_ADSENSE_CLIENT
const beaconToken = import.meta.env.PUBLIC_CF_BEACON_TOKEN
const cfAnalyticsEnabled = import.meta.env.PUBLIC_ENABLE_CF_ANALYTICS === 'true'
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex" />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="oriz" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@chirag127" />
    <meta name="theme-color" content="#15110D" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="alternate" type="application/rss+xml" title="oriz · RSS" href="/rss.xml" />
    <link rel="alternate" type="application/atom+xml" title="oriz · Atom" href="/atom.xml" />
    <link rel="alternate" type="application/feed+json" title="oriz · JSON Feed" href="/feed.json" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Newsreader:opsz,ital,wght@6..72,0,400;6..72,0,600;6..72,0,700;6..72,1,400&family=Inter+Tight:ital,wght@0,400;0,500;0,600;1,400&family=JetBrains+Mono:wght@400;500&display=swap"
    />

    <JsonLd extra={jsonLd} pageUrl={canonical} />

    {
      adsenseClient && (
        <script
          is:inline
          async
          src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsenseClient}`}
          crossorigin="anonymous"
        />
      )
    }

    {
      cfAnalyticsEnabled && beaconToken && (
        <script
          is:inline
          defer
          src="https://static.cloudflareinsights.com/beacon.min.js"
          data-cf-beacon={`{"token": "${beaconToken}"}`}
        />
      )
    }
  </head>
  <body class={bodyClass}>
    <a href="#main" class="skip-link">Skip to content</a>
    {chrome === 'full' ? (
      <>
        <Header />
        <div class="layout-body">
          <Sidebar><AppSidebarContent /></Sidebar>
          <main id="main"><slot /></main>
        </div>
        <Footer>
          <div slot="pre" class="family-sites-grid">
            <h2 class="family-sites-h">Family sites</h2>
            <ul>
              {FAMILY_SITES.map((s) => (
                <li><a href={s.url}>{s.name}</a></li>
              ))}
            </ul>
          </div>
        </Footer>
        <BottomBar actions={bottomBarActions} />
      </>
    ) : (
      <main id="main"><slot /></main>
    )}
    <ConsentBanner />
  </body>
</html>

<style>
  .layout-body { display: flex; gap: 1rem; }
  @media (max-width: 767px) { .layout-body { display: block; } }
</style>
