---
/*
 * BaseLayout — single page shell for every oriz-home route.
 *
 * v2 broadsheet almanac. Dark spine. No theme picker (the brief allows a
 * light variant via prefers-color-scheme but nothing user-toggleable).
 * Header is a 56px masthead-meta strip; footer is the 4-column sitemap
 * (band 4 / colophon).
 *
 * Family-anchor pattern: sister sites copy this skeleton and just change
 * the wordmark subtitle prop and the Google Fonts list.
 *
 * 2026-06-20 wiring (this commit):
 *   • Default <JsonLd> Organization + WebSite + Person triple in <head>.
 *   • Page-level `jsonLd` prop appends additional blocks (no replacement).
 *   • <FeedDiscovery /> link tags for /rss.xml + /atom.xml + /feed.json.
 *   • CF Web Analytics gated behind PUBLIC_ENABLE_CF_ANALYTICS=true.
 *   • <ConsentBanner /> mounted before </body> — Klaro lazy script.
 *   • Header now mounts <StatusBanner /> + <MultiSearch /> as React islands.
 */
import '~/styles/global.css'
import '~/styles/oriz-ui-overrides.css'
import Footer from '~/components/Footer.astro'
import Header from '~/components/Header.astro'
import JsonLd from '~/components/JsonLd.astro'
import ConsentBanner from '@chirag127/astro-chrome/ConsentBanner.astro'

interface Props {
  title?: string
  description?: string
  canonical?: string
  noindex?: boolean
  /** Page-level JSON-LD blocks appended to the default Org+WebSite+Person triple. */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[]
  /** Subtitle shown after `oriz /` in the wordmark. Default: `home`. */
  wordmarkSubtitle?: string
  /**
   * Layout chrome.
   *   'full' → broadsheet Header + Footer (default; sub-pages use this).
   *   'bare' → no Header / no Footer; the page renders its own minimal scaffold.
   *            The Alphabet-style homepage uses this.
   */
  chrome?: 'full' | 'bare'
  /** Body class name (e.g. 'home-bare' to flip to white-paper / serif). */
  bodyClass?: string
}

const {
  title = 'oriz — a family of small, free, static sites by Chirag Singhal',
  description = 'A free family of static sites: book summaries, NCERT directory, India card intelligence, finance calculators, dev tools, blog, and a privacy-first journal.',
  canonical = `https://oriz.in${Astro.url.pathname}`,
  noindex = false,
  jsonLd,
  wordmarkSubtitle = 'home',
  chrome = 'full',
  bodyClass,
} = Astro.props

const adsenseClient = import.meta.env.PUBLIC_ADSENSE_CLIENT
const beaconToken = import.meta.env.PUBLIC_CF_BEACON_TOKEN
const cfAnalyticsEnabled = import.meta.env.PUBLIC_ENABLE_CF_ANALYTICS === 'true'
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex" />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="oriz" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@chirag127" />
    <meta name="theme-color" content="#15110D" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {/*
      Feed discovery — three formats per
      knowledge/decisions/architecture/feeds-rss-atom-json.md.
      Cross-link to canonical apex feeds (oriz.in) from every site.
    */}
    <link rel="alternate" type="application/rss+xml" title="oriz · RSS" href="/rss.xml" />
    <link rel="alternate" type="application/atom+xml" title="oriz · Atom" href="/atom.xml" />
    <link rel="alternate" type="application/feed+json" title="oriz · JSON Feed" href="/feed.json" />

    {/*
      Type stack — the family-anchor combo. Newsreader (display, with optical-size
      axis dragged toward 36 for the masthead lockup) + Inter Tight (body) +
      JetBrains Mono (numerals, sub-domain strings, mono labels). NO Fraunces.
    */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Newsreader:opsz,ital,wght@6..72,0,400;6..72,0,600;6..72,0,700;6..72,1,400&family=Inter+Tight:ital,wght@0,400;0,500;0,600;1,400&family=JetBrains+Mono:wght@400;500&display=swap"
    />

    {/* Default Organization + WebSite + Person triple. */}
    <JsonLd extra={jsonLd} pageUrl={canonical} />

    {
      adsenseClient && (
        <script
          is:inline
          async
          src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsenseClient}`}
          crossorigin="anonymous"
        />
      )
    }

    {/* Cloudflare Web Analytics — cookie-less, gated by PUBLIC_ENABLE_CF_ANALYTICS. */}
    {
      cfAnalyticsEnabled && beaconToken && (
        <script
          is:inline
          defer
          src="https://static.cloudflareinsights.com/beacon.min.js"
          data-cf-beacon={`{"token": "${beaconToken}"}`}
        />
      )
    }
  </head>
  <body class={bodyClass}>
    <a href="#main" class="skip-link">Skip to content</a>
    {chrome === 'full' && <Header wordmarkSubtitle={wordmarkSubtitle} />}
    <main id="main"><slot /></main>
    {chrome === 'full' && <Footer />}
    <ConsentBanner />
  </body>
</html>
