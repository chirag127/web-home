---
/*
 * /contact — Web3Forms-backed static form. No JS island; the form posts
 * directly to api.web3forms.com.
 *
 * Markup uses the `[data-chirag127ntact-*]` selector hooks so the same
 * overrides CSS in src/styles/ui-overrides.css styles both this
 * static form and any future dynamic ContactForm island. Sister sites
 * can swap to the React ContactForm component without rewriting their CSS.
 */
import BaseLayout from '~/layouts/BaseLayout.astro'

const web3formsKey = import.meta.env.PUBLIC_WEB3FORMS_KEY ?? ''
---

<BaseLayout
  title="Contact — chirag127"
  description="Get in touch about anything on oriz.in."
  wordmarkSubtitle="contact"
  sidebar={false}
>
  <header class="spine page-head">
    <p class="eyebrow"><a href="/">chirag127</a> / contact</p>
    <h1>Contact</h1>
    <p class="lede">
      Email is fastest: <a href="mailto:whyiswhen@gmail.com">whyiswhen@gmail.com</a>.
    </p>
  </header>

  <section class="spine prose">
    <p>
      For anything site-related — typo on a page, broken link, suggestion — use the form below. It
      posts to <a href="https://web3forms.com">Web3Forms</a> which forwards to my inbox. No data is
      stored on this site.
    </p>

    <form
      action="https://api.web3forms.com/submit"
      method="POST"
      data-chirag127ntact
      data-chirag127ntact-status="idle"
    >
      <input type="hidden" name="access_key" value={web3formsKey} />
      <input type="hidden" name="from_name" value="oriz.in contact form" />
      <input
        type="text"
        name="botcheck"
        data-chirag127ntact-honeypot
        tabindex="-1"
        autocomplete="off"
      />

      <label data-chirag127ntact-field="name">
        <span>Your name</span>
        <input type="text" name="name" required autocomplete="name" />
      </label>
      <label data-chirag127ntact-field="email">
        <span>Email</span>
        <input type="email" name="email" required autocomplete="email" />
      </label>
      <label data-chirag127ntact-field="subject">
        <span>Subject</span>
        <input type="text" name="subject" required />
      </label>
      <label data-chirag127ntact-field="message">
        <span>Message</span>
        <textarea name="message" rows="6" required></textarea>
      </label>

      <button type="submit" data-chirag127ntact-submit>Send</button>
    </form>

    <p class="meta">
      For privacy questions or DMCA notices, see the
      <a href="/legal/grievance/">grievance officer</a> page (mandatory under IT Rules 2021).
    </p>
  </section>
</BaseLayout>

<style>
  .meta {
    font-size: 0.875rem;
    color: var(--ink-mute);
    margin-top: 2rem;
  }
</style>
