---
import AppCard from '~/components/AppCard.astro'
import type { Channel } from '~/data/apps'
import { APPS } from '~/data/apps'
/*
 * /mobile — Android distribution channels per app.
 *
 * For each oriz app, we render an AppCard with two channel badges:
 *   - Play Store  (when a published listing URL is set in apps.ts)
 *   - APK direct  (when a GH Release has a .apk asset — auto-discovered)
 *
 * Apps with no Play Store + no APK release show 'Coming soon — Android
 * via PWABuilder' badges. Per knowledge/decisions/architecture/
 * pwabuilder-as-primary-converter.md, Android binaries come from
 * PWABuilder's TWA generator (AAB → Play Console).
 *
 * iOS is intentionally excluded — per the memory rule
 * `ios-pwa-only-no-mac.md`, oriz ships iOS as a PWA only, never via the
 * App Store.
 */
import BaseLayout from '~/layouts/BaseLayout.astro'

const MOBILE_CHANNELS: Channel[] = ['play_store', 'github_release_apk']

/* Exclude the hub itself and personal lifestream — neither makes sense as
 * a native Android app. */
const apps = APPS.filter((a) => a.category !== 'hub' && a.category !== 'personal')
---

<BaseLayout
  title="Mobile — oriz"
  description="Android distribution channels for every oriz app. Install from the Play Store or sideload via APK. iOS ships as a PWA only."
  wordmarkSubtitle="mobile"
>
  <article class="page spine">
    <h1 class="page-title">Mobile</h1>
    <p class="page-lede">
      Android distribution for every oriz app. Use the Play Store where
      available, or sideload the signed APK from GitHub Releases.
      iOS ships as a PWA only — every app installs from its subdomain via
      Safari's <em>Add to Home Screen</em>.
    </p>

    <p class="page-note">
      Most apps are <em>coming soon</em> — Android packages are generated by
      <a href="https://www.pwabuilder.com/">PWABuilder</a> from each app's PWA,
      then published as we go. Until then, install the PWA directly from each
      app's subdomain.
    </p>

    <section class="app-section">
      <div class="app-grid">
        {apps.map((app) => <AppCard app={app} channels={MOBILE_CHANNELS} />)}
      </div>
    </section>
  </article>
</BaseLayout>

<style>
  .page {
    padding-block: clamp(2rem, 5vw, 3rem) clamp(3rem, 6vw, 4rem);
  }
  .page-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(2rem, 5vw, 2.75rem);
    margin: 0 0 0.5rem;
    color: var(--ink);
  }
  .page-lede,
  .page-note {
    font-family: var(--font-display);
    font-size: 1.0625rem;
    color: var(--ink);
    max-width: 60ch;
    margin: 0 0 1rem;
  }
  .page-note {
    color: var(--ink-mute);
    border-left: 2px solid var(--rule);
    padding-left: 0.75rem;
    margin-bottom: 2rem;
  }
  .app-section {
    margin-top: 1.5rem;
  }
  .app-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }
</style>
