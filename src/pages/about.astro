---
/*
 * /about — Chirag bio + the seven engineering principles.
 *
 * Single broadsheet column. Numbered principle list ties to the index
 * page's numbered TOC pattern (the `01–11` numerals are a family motif).
 */
import BaseLayout from '~/layouts/BaseLayout.astro'

const PRINCIPLES = [
  {
    title: 'Static first',
    body: 'Every site is a static build. No backend to scale, no server to pay for, no 3am page. Everything that can run in your browser does.',
  },
  {
    title: 'Privacy by default',
    body: "No tracking beyond Cloudflare's anonymous first-party analytics. Journal entries are end-to-end encrypted. PDF and image tools never upload — they run in your browser.",
  },
  {
    title: 'Free, no paywall',
    body: 'Display ads on a few sites cover the domain renewal. There is no pro tier, no upsell, no gated feature. If a site is useful, that is enough.',
  },
  {
    title: 'Owned, not rented',
    body: 'I own the content, the code, and the domain. Every site lives in its own GitHub repository under chirag127/*. If a hosting provider disappears, the data is mine.',
  },
  {
    title: 'Small surface',
    body: 'A handful of small sites, each with one job. The shared design system means you only learn the controls once.',
  },
  {
    title: 'Long horizon',
    body: 'A 100-year operating plan: git is canonical, cloud caches are secondary. If everything else fails, a public JSONL mirror on GitHub Pages is the fallback.',
  },
  {
    title: 'Quiet',
    body: 'No popups. No newsletters you didn\'t ask for. No "would you like to enable notifications" prompts. The web is loud enough.',
  },
] as const

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Chirag Singhal',
  url: 'https://oriz.in/about/',
  jobTitle: 'Software Engineer',
  description:
    'Software engineer specializing in scalable backend architectures, full-stack development, AI agents, and cloud-native deployments.',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Bhubaneswar',
    addressRegion: 'Odisha',
    addressCountry: 'IN',
  },
  sameAs: [
    'https://github.com/chirag127',
    'https://x.com/chirag127',
    'https://linkedin.com/in/chirag127',
  ],
}
---

<BaseLayout
  title="About — Chirag Singhal"
  description="Software engineer based in Bhubaneswar. Builder of the chirag127 family of sites."
  jsonLd={jsonLd}
  wordmarkSubtitle="about"
  sidebar={false}
>
  <header class="spine page-head">
    <p class="eyebrow"><a href="/">chirag127</a> / about</p>
    <h1>About</h1>
    <p class="lede">
      Chirag Singhal — software engineer, Bhubaneswar. Builder of the chirag127 family.
    </p>
  </header>

  <article class="spine prose">
    <p class="lede">
      I am Chirag Singhal — a software engineer based in Bhubaneswar, Odisha. I build small, fast,
      free things on the open web.
    </p>

    <h2>What is chirag127</h2>
    <p>
      <strong>chirag127</strong> is the umbrella for everything I publish — a family of static sites that
      share a design system and a single principle:{' '}
      <em>useful, free, and quiet</em>. Each site is its own GitHub repository, stitched together
      through{' '}
      <a href="https://github.com/chirag127/chirag127">chirag127/chirag127</a>, a hub that holds them as git
      submodules. Everything is hosted on Cloudflare as fully-public static sites — no accounts, no
      backend. Donations cover the domain renewal.
    </p>

    <h2>Seven principles</h2>
    <ol class="principles">
      {
        PRINCIPLES.map((p, i) => (
          <li class="principle">
            <span class="num mono">{String(i + 1).padStart(2, '0')}</span>
            <div class="meat">
              <h3>{p.title}</h3>
              <p>{p.body}</p>
            </div>
          </li>
        ))
      }
    </ol>

    <h2>Day job</h2>
    <p>
      Backend systems, distributed databases, cloud platforms. Off-hours: writing, building these
      tools, reading. If something on chirag127 is useful to you, that is enough.
    </p>

    <h2>Contact</h2>
    <p>
      Email: <a href="mailto:whyiswhen@gmail.com">whyiswhen@gmail.com</a>. Use the{' '}
      <a href="/contact/">contact form</a> for anything site-related — typo, broken link,
      suggestion. For privacy questions or DMCA notices, the{' '}
      <a href="/legal/grievance/">grievance officer</a> page is the formal channel (mandatory under
      IT Rules 2021).
    </p>
  </article>
</BaseLayout>

<style>
  .principles {
    list-style: none;
    padding: 0;
    margin: 0 0 2rem;
    border-top: 1px solid var(--rule);
  }
  .principle {
    display: grid;
    grid-template-columns: 56px 1fr;
    gap: 1rem;
    padding-block: 1.25rem;
    border-bottom: 1px solid var(--rule);
    margin: 0;
  }
  .principle .num {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--ink-mute);
    padding-top: 0.4rem;
    font-feature-settings:
      'tnum' 1,
      'zero' 1,
      'calt' 0;
  }
  .principle .meat h3 {
    margin: 0 0 0.375rem;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.1875rem;
    color: var(--ink);
  }
  .principle .meat p {
    margin: 0;
    color: color-mix(in oklab, var(--ink) 88%, var(--paper));
    line-height: 1.6;
    font-size: 1rem;
  }
</style>
