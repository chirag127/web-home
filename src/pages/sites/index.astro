---
/*
 * /sites — full sites list with category groupings.
 *
 * Same broadsheet column. Re-uses the .index-row pattern from index.astro
 * (deduplicated CSS lives there in :global form, but for now this page
 * keeps an inline copy — when the second sister site copies this page,
 * the rules can move to global.css under .index-row).
 *
 * Order is by category, then alphabetical within category. Categories:
 *   READING / WRITING / TOOLS / FINANCE / PERSONAL
 */
import BaseLayout from '~/layouts/BaseLayout.astro'
import { FAMILY_SITES } from '~/lib/family'

const CAT_ORDER = ['reading', 'tools', 'finance', 'personal'] as const
const CAT_LABELS: Record<(typeof CAT_ORDER)[number], string> = {
  reading: 'READ + WRITE',
  tools: 'MAKE + TOOLS',
  finance: 'TRACK',
  personal: 'META',
}

const grouped = CAT_ORDER.map((cat) => ({
  cat,
  label: CAT_LABELS[cat],
  sites: FAMILY_SITES.filter((s) => s.category === cat),
}))
---

<BaseLayout
  title="All sites — oriz"
  description="Every site in the oriz family — books, blog, NCERT, cards, finance, journal, URL-to-Markdown, image tools, PDF tools, datasheet."
  wordmarkSubtitle="sites"
>
  <header class="spine page-head">
    <p class="eyebrow"><a href="/">oriz</a> / sites</p>
    <h1>The oriz family</h1>
    <p class="lede">
      {FAMILY_SITES.length} sites. No sign-in. All free, all open source.
    </p>
  </header>

  <section class="spine sites-section" aria-label="All sites">
    {
      grouped.map((g) => (
        <div class="cat-block">
          <h2 class="cat-h mono">{g.label}</h2>
          <ol class="index-list">
            {g.sites.map((s) => (
              <li class="index-row-wrap">
                <a class="index-row" href={s.url}>
                  <span class="cat mono">{s.slug}</span>
                  <span class="meat">
                    <span class="name display">{s.name}</span>
                    <span class="desc">{s.tagline}</span>
                  </span>
                  <span class="domain mono">{new URL(s.url).host}</span>
                </a>
              </li>
            ))}
          </ol>
        </div>
      ))
    }
  </section>
</BaseLayout>

<style>
  .sites-section {
    padding-block: 2.5rem 5rem;
  }
  .cat-block {
    margin-bottom: 2.5rem;
  }
  .cat-block:last-child {
    margin-bottom: 0;
  }
  .cat-h {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--ink-mute);
    margin: 0 0 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--rule);
    font-feature-settings:
      'tnum' 1,
      'zero' 1,
      'calt' 0;
  }

  /* Mirror the .index-row pattern from index.astro (3-col on this page —
     no number column since it's grouped). */
  .index-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .index-row-wrap {
    border-bottom: 1px solid color-mix(in oklab, var(--ink-mute) 20%, transparent);
  }
  .index-row-wrap:last-child {
    border-bottom: 0;
  }
  .index-row {
    display: grid;
    grid-template-columns: 100px 1fr 220px;
    gap: 1rem;
    align-items: center;
    min-height: 56px;
    padding-block: 0.75rem;
    text-decoration: none;
    color: var(--ink);
  }
  .index-row .cat {
    color: var(--ink-mute);
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.16em;
  }
  .index-row .meat {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    min-width: 0;
  }
  .index-row .name {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 20px;
    color: var(--ink);
    line-height: 1.15;
  }
  .index-row .desc {
    font-family: var(--font-sans);
    font-size: 14px;
    color: var(--ink-mute);
    line-height: 1.4;
  }
  .index-row .domain {
    color: var(--ink-mute);
    font-family: var(--font-mono);
    font-size: 12px;
    text-align: right;
    font-feature-settings:
      'tnum' 1,
      'zero' 1,
      'calt' 0;
  }

  /* Monochrome-until-hover — same signature as the home index. */
  .index-row:hover {
    box-shadow: inset 0 -1px 0 var(--mustard);
  }
  .index-row:hover .cat {
    color: var(--mustard);
  }
  .index-row:hover .domain {
    color: var(--ledger);
  }
  .index-row:focus-visible {
    outline: none;
    background: color-mix(in oklab, var(--highlighter) 30%, transparent);
    box-shadow: inset 0 -1px 0 var(--mustard);
  }
  .index-row:focus-visible .cat {
    color: var(--mustard);
  }
  .index-row:focus-visible .domain {
    color: var(--ledger);
  }

  @media (max-width: 640px) {
    .index-row {
      grid-template-columns: 1fr;
      grid-template-areas:
        'cat'
        'meat'
        'domain';
      row-gap: 0.25rem;
      padding-block: 0.875rem;
    }
    .index-row .cat {
      grid-area: cat;
    }
    .index-row .meat {
      grid-area: meat;
    }
    .index-row .domain {
      grid-area: domain;
      text-align: left;
    }
  }
</style>
