---
import Wordmark from '~/components/Wordmark.astro'
/*
 * oriz / home — index page (the broadsheet almanac).
 *
 * Single 920px column. Four bands:
 *   1. Header (already mounted by BaseLayout).
 *   2. Masthead lockup (the hero) — wordmark + manifesto + start-arrow.
 *   3. The Index — numbered TOC table, 11 rows, monochrome-until-hover.
 *   4. Footer (already mounted by BaseLayout) — sitemap + colophon.
 *
 * Family-anchor patterns established here:
 *   • The .index-row markup (number + category + name + description + sub-domain)
 *     is the canonical "list of children" shape. Sister sites with sub-section
 *     lists (e.g. blog post index, tool list) re-use it.
 *   • The monochrome-until-hover CSS lives in global.css under .index-row;
 *     other sites that want the same behaviour copy those rules.
 *   • The single vermilion .start-arrow is the only first-paint color exception.
 */
import BaseLayout from '~/layouts/BaseLayout.astro'
import { FAMILY_SITES } from '~/lib/family'

/*
 * The 11-row index. Each FAMILY_SITES entry is annotated with:
 *   - cat: the broadsheet category (READ / WRITE / MAKE / TOOL / TRACK / META)
 *   - desc: a one-line description (overrides FAMILY_SITES.tagline for tighter copy)
 *
 * Order matters — the brief says "01 books, 02 book-lore, 03 blog, …".
 * Home is META, last (10), with description "This page."
 */
type IndexCat = 'READ' | 'WRITE' | 'MAKE' | 'TOOL' | 'TRACK' | 'META'

interface IndexRow {
  slug: string
  cat: IndexCat
  desc: string
}

const ROWS: IndexRow[] = [
  { slug: 'books', cat: 'READ', desc: 'A second-life library, by-default-public.' },
  { slug: 'book-lore', cat: 'READ', desc: 'Marginalia worth keeping — 461 book summaries.' },
  { slug: 'blog', cat: 'WRITE', desc: 'Long-form notes, drafted in the open.' },
  { slug: 'journal', cat: 'WRITE', desc: 'End-to-end-encrypted daily entries.' },
  { slug: 'cards', cat: 'MAKE', desc: '750 India card profiles — credit, debit, prepaid.' },
  { slug: 'urls-to-md', cat: 'MAKE', desc: 'Paste a URL, get a clean Markdown file.' },
  { slug: 'pdf-tools', cat: 'TOOL', desc: 'Merge, split, redact — never uploads.' },
  { slug: 'image-tools', cat: 'TOOL', desc: 'Convert, compress, scrub EXIF locally.' },
  { slug: 'finance', cat: 'TRACK', desc: 'Graph-paper ledger for personal money.' },
  { slug: 'me', cat: 'META', desc: 'Daily-rebuilt digital identity datasheet.' },
  { slug: 'home', cat: 'META', desc: 'This page.' },
]

const sitesBySlug = Object.fromEntries(FAMILY_SITES.map((s) => [s.slug, s]))
const indexEntries = ROWS.map((row, i) => {
  const s = sitesBySlug[row.slug]
  if (!s) throw new Error(`oriz-home/index.astro: FAMILY_SITES has no entry for ${row.slug}`)
  return {
    n: String(i + 1).padStart(2, '0'),
    cat: row.cat,
    desc: row.desc,
    name: s.name,
    url: s.url,
    domain: new URL(s.url).host,
  }
})

// Organization + WebSite + Person triple is emitted by BaseLayout's
// <JsonLd> default; the index page contributes nothing extra.
---

<BaseLayout>
  {/*
    Band 2 — Masthead lockup. The wordmark IS the hero. No illustration,
    no gradient, no 3D blob. The only first-paint vermilion is the strike
    through the `z` (inside Wordmark.astro) and the .start-arrow below.
  */}
  <section class="spine masthead">
    <Wordmark size={128} href={null} asHeading={true} />

    <p class="manifesto display">
      <span>eleven</span><span class="dot">·</span>
      <span>small</span><span class="dot">·</span>
      <span>free</span><span class="dot">·</span>
      <span>sites</span>
    </p>
    <p class="manifesto subtle">
      one <span class="dot">·</span> sign-in <span class="dot">·</span> one
      <span class="dot">·</span> person <span class="dot">·</span> one
      <span class="dot">·</span> /etc
    </p>

    <a href="#index" class="start-arrow">start anywhere ↓</a>
  </section>

  {/*
    Band 3 — The index (numbered TOC). 11 rows. Whole-row clickable.
    Monochrome-until-hover signature lives in the .index-row CSS below.
  */}
  <hr class="hairline spine-rule" />
  <section class="spine index" id="index" aria-label="The index">
    <ol class="index-list">
      {
        indexEntries.map((e) => (
          <li class="index-row-wrap">
            <a class="index-row" href={e.url}>
              <span class="num mono">{e.n}</span>
              <span class="cat mono">{e.cat}</span>
              <span class="meat">
                <span class="name display">{e.name}</span>
                <span class="desc">{e.desc}</span>
              </span>
              <span class="domain mono">{e.domain}</span>
            </a>
          </li>
        ))
      }
    </ol>
  </section>
  <hr class="hairline spine-rule" />
</BaseLayout>

<style>
  /* ── Band 2: masthead lockup ────────────────────────────────────────── */

  .masthead {
    text-align: center;
    padding-block: clamp(3rem, 9vw, 6rem) clamp(2.5rem, 7vw, 5rem);
  }

  /* The wordmark inherits its size from the Wordmark.astro `size` prop.
     We just want it centered and on its own line. */
  .masthead :global(.wordmark) {
    margin: 0 auto;
    /* Drop the optical-size axis as far as Newsreader allows for display. */
    font-variation-settings: 'opsz' 60;
    letter-spacing: 0.04em;
  }

  .manifesto {
    margin: 1.75rem auto 0;
    color: var(--ink-mute);
    line-height: 1.4;
  }
  .manifesto.display {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
  }
  .manifesto.subtle {
    font-family: var(--font-sans);
    font-style: italic;
    font-weight: 400;
    font-size: 1rem;
    margin-top: 0.5rem;
  }
  .manifesto .dot {
    margin-inline: 0.45em;
    color: var(--ink-mute);
    /* The brief explicitly forbids vermilion · separators. Stay in --ink-mute. */
  }

  .start-arrow {
    display: inline-block;
    margin-top: clamp(2rem, 6vw, 3.5rem);
    padding: 0.5rem 1rem;
    color: var(--vermilion);
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.02em;
    text-decoration: none;
    border-bottom: 1px solid var(--vermilion);
  }
  .start-arrow:hover {
    background: color-mix(in oklab, var(--vermilion) 12%, transparent);
  }
  .start-arrow:focus-visible {
    outline: 2px solid var(--vermilion);
    outline-offset: 3px;
  }

  /* ── Band 3: the index ──────────────────────────────────────────────── */

  .spine-rule {
    /* Section dividers around the index — same weight as header rules. */
  }

  .index {
    padding-block: 0;
  }
  .index-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .index-row-wrap {
    border-bottom: 1px solid color-mix(in oklab, var(--ink-mute) 20%, transparent);
  }
  .index-row-wrap:last-child {
    border-bottom: 0;
  }

  .index-row {
    display: grid;
    grid-template-columns: 48px 88px 1fr 220px;
    gap: 1rem;
    align-items: center;
    min-height: 64px;
    padding-block: 0.875rem;
    text-decoration: none;
    color: var(--ink); /* default — no accents at rest */
  }
  .index-row .num {
    color: var(--ink-mute);
    font-family: var(--font-mono);
    font-size: 13px;
  }
  .index-row .cat {
    color: var(--ink-mute);
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.16em;
  }
  .index-row .meat {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    min-width: 0;
  }
  .index-row .name {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 22px;
    line-height: 1.15;
    color: var(--ink); /* explicit ink — no first-paint color */
    letter-spacing: -0.005em;
  }
  .index-row .desc {
    font-family: var(--font-sans);
    font-size: 14px;
    color: var(--ink-mute);
    line-height: 1.4;
  }
  .index-row .domain {
    color: var(--ink-mute);
    font-family: var(--font-mono);
    font-size: 12px;
    text-align: right;
    font-feature-settings:
      'tnum' 1,
      'zero' 1,
      'calt' 0;
  }

  /*
   * THE signature — monochrome-until-hover.
   * Default state above is ink-on-paper only. On :hover or :focus-visible,
   * the row "comes alive" — mustard category + numerals, ledger green
   * sub-domain, mustard 1px hairline at the bottom.
   */
  .index-row:hover {
    box-shadow: inset 0 -1px 0 var(--mustard);
  }
  .index-row:hover .num,
  .index-row:hover .cat {
    color: var(--mustard);
  }
  .index-row:hover .domain {
    color: var(--ledger);
  }
  .index-row:hover .name {
    color: var(--ink); /* name stays ink — only labels and domain shift */
  }

  .index-row:focus-visible {
    outline: none;
    background: color-mix(in oklab, var(--highlighter) 30%, transparent);
    box-shadow: inset 0 -1px 0 var(--mustard);
  }
  .index-row:focus-visible .num,
  .index-row:focus-visible .cat {
    color: var(--mustard);
  }
  .index-row:focus-visible .domain {
    color: var(--ledger);
  }

  /* Mobile — collapse the 4-col grid to a 2-row stack. */
  @media (max-width: 640px) {
    .index-row {
      grid-template-columns: 36px 1fr;
      grid-template-areas:
        'num    cat'
        'meat   meat'
        'domain domain';
      row-gap: 0.25rem;
      padding-block: 1rem;
    }
    .index-row .num {
      grid-area: num;
    }
    .index-row .cat {
      grid-area: cat;
      text-align: right;
    }
    .index-row .meat {
      grid-area: meat;
    }
    .index-row .domain {
      grid-area: domain;
      text-align: left;
    }
  }
</style>
