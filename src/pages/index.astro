---
/*
 * chirag127 / home — index page (hub redesign 2026-07-08).
 *
 * Sections:
 *   1. Hero / Bio    — name, role, stats, CTA buttons
 *   2. Sites         — all live oriz.in subdomains as cards
 *   3. API fleet     — 16 endpoints as a grid
 *   4. Packages      — 17 @chirag127/* npm packages
 *
 * Design: MD3 dark — #0F0D13 bg, #D0BCFF primary, Google Sans typography.
 * CSS: standalone CSS custom properties, no Tailwind classes.
 */
import BaseLayout from '~/layouts/BaseLayout.astro'

/* ── 2 · Sites ───────────────────────────────────────────────────────── */
const SITES = [
  {
    name: 'me.oriz.in',
    desc: 'Personal OS — lifestream, now-page, uses, CV, contact.',
    url: 'https://me.oriz.in',
  },
  {
    name: 'blog.oriz.in',
    desc: 'Long-form essays on engineering, finance, and books.',
    url: 'https://blog.oriz.in',
  },
  {
    name: 'books.oriz.in',
    desc: 'Free NCERT textbook directory — class, subject, language.',
    url: 'https://books.oriz.in',
  },
  {
    name: 'janaushdhi.oriz.in',
    desc: 'PMBJP generic-medicine catalog — search, compare, locate.',
    url: 'https://janaushdhi.oriz.in',
  },
  {
    name: 'pkg-md3-tokens.oriz.in',
    desc: 'MD3 design-system token reference and explorer.',
    url: 'https://pkg-md3-tokens.oriz.in',
  },
  {
    name: 'pkg-astro-seo.oriz.in',
    desc: 'Astro SEO component docs and playground.',
    url: 'https://pkg-astro-seo.oriz.in',
  },
  {
    name: 'pkg-astro-analytics.oriz.in',
    desc: 'Astro analytics integration docs.',
    url: 'https://pkg-astro-analytics.oriz.in',
  },
  {
    name: 'pkg-astro-chrome.oriz.in',
    desc: 'Astro app shell (header, footer, sidebar) docs.',
    url: 'https://pkg-astro-chrome.oriz.in',
  },
  {
    name: 'pkg-astro-shell.oriz.in',
    desc: 'Astro shell token system docs.',
    url: 'https://pkg-astro-shell.oriz.in',
  },
]

/* ── 3 · API fleet ───────────────────────────────────────────────────── */
const APIS = [
  { slug: 'rto', host: 'api-rto.oriz.in', desc: 'RTO vehicle registration data' },
  {
    slug: 'constants',
    host: 'api-constants.oriz.in',
    desc: 'Indian constants and reference values',
  },
  {
    slug: 'dynasties',
    host: 'api-dynasties.oriz.in',
    desc: 'Indian dynasties and historical data',
  },
  {
    slug: 'countries-plus',
    host: 'api-countries-plus.oriz.in',
    desc: 'Country data with India-focused extras',
  },
  { slug: 'ragas', host: 'api-ragas.oriz.in', desc: 'Hindustani and Carnatic raga database' },
  { slug: 'air-quality', host: 'api-air-quality.oriz.in', desc: 'Live AQI for Indian cities' },
  {
    slug: 'currency-rates',
    host: 'api-currency-rates.oriz.in',
    desc: 'Live currency exchange rates',
  },
  { slug: 'fii-dii', host: 'api-fii-dii.oriz.in', desc: 'FII and DII daily investment data' },
  {
    slug: 'gold-silver',
    host: 'api-gold-silver.oriz.in',
    desc: 'Live gold and silver prices (India)',
  },
  { slug: 'ifsc', host: 'api-ifsc.oriz.in', desc: 'IFSC code lookup for Indian bank branches' },
  { slug: 'budget', host: 'api-budget.oriz.in', desc: 'Union Budget allocations and data' },
  {
    slug: 'holidays',
    host: 'api-holidays.oriz.in',
    desc: 'Indian public holidays by state and year',
  },
  {
    slug: 'petrol-diesel',
    host: 'api-petrol-diesel.oriz.in',
    desc: 'Daily petrol and diesel prices by city',
  },
  {
    slug: 'train-schedules',
    host: 'api-train-schedules.oriz.in',
    desc: 'Indian Railways train schedules',
  },
  { slug: 'weather', host: 'api-weather.oriz.in', desc: 'Current weather for Indian cities' },
  {
    slug: 'mmi-tickertape',
    host: 'api-mmi-tickertape.oriz.in',
    desc: 'Market Mood Index and Tickertape data',
  },
]

/* ── 4 · Packages ─────────────────────────────────────────────────────
 * 17 @chirag127/* npm packages with pkg-*.oriz.in landing pages.
 * ─────────────────────────────────────────────────────────────────── */
const PACKAGES = [
  { slug: 'md3-tokens', pkgSite: 'pkg-md3-tokens.oriz.in' },
  { slug: 'astro-seo', pkgSite: 'pkg-astro-seo.oriz.in' },
  { slug: 'astro-analytics', pkgSite: 'pkg-astro-analytics.oriz.in' },
  { slug: 'astro-chrome', pkgSite: 'pkg-astro-chrome.oriz.in' },
  { slug: 'astro-shell', pkgSite: 'pkg-astro-shell.oriz.in' },
  { slug: 'astro-billing', pkgSite: 'pkg-astro-billing.oriz.in' },
  { slug: 'astro-content', pkgSite: 'pkg-astro-content.oriz.in' },
  { slug: 'astro-data', pkgSite: 'pkg-astro-data.oriz.in' },
  { slug: 'astro-forms', pkgSite: 'pkg-astro-forms.oriz.in' },
  { slug: 'astro-pwa', pkgSite: 'pkg-astro-pwa.oriz.in' },
  { slug: 'astro-tools', pkgSite: 'pkg-astro-tools.oriz.in' },
  { slug: 'astro-widgets', pkgSite: 'pkg-astro-widgets.oriz.in' },
  { slug: 'auth-core', pkgSite: 'pkg-auth-core.oriz.in' },
  { slug: 'omni-publish', pkgSite: 'pkg-omni-publish.oriz.in' },
  { slug: 'ai-providers', pkgSite: 'pkg-ai-providers.oriz.in' },
  { slug: 'seo', pkgSite: 'pkg-seo.oriz.in' },
  { slug: 'rate-limit', pkgSite: 'pkg-rate-limit.oriz.in' },
]
---

<BaseLayout
  title="Chirag Singhal — Software Engineer, oriz.in"
  description="Chirag Singhal — Software Engineer at TCS. 353+ repos, 192+ tools, open-source packages and free APIs."
  sidebar={false}
>
  <article class="hub spine">

    {/* ── 1 · Hero / Bio ──────────────────────────────────────────────── */}
    <section class="hero" aria-label="Bio">
      <div class="hero-inner">
        <p class="hero-eyebrow">Software Engineer</p>
        <h1 class="hero-name">Chirag Singhal</h1>
        <p class="hero-role">@ TCS &middot; Available for opportunities</p>
        <ul class="hero-stats" aria-label="Stats">
          <li class="stat-chip"><span class="stat-n">353+</span><span class="stat-l">repos</span></li>
          <li class="stat-chip"><span class="stat-n">53h</span><span class="stat-l">/week coding</span></li>
          <li class="stat-chip"><span class="stat-n">192+</span><span class="stat-l">tools</span></li>
          <li class="stat-chip"><span class="stat-n">16</span><span class="stat-l">free APIs</span></li>
        </ul>
        <div class="hero-ctas">
          <a class="cta-primary" href="https://me.oriz.in">me.oriz.in &rarr;</a>
          <a class="cta-secondary" href="https://github.com/chirag127">github.com/chirag127 &rarr;</a>
        </div>
      </div>
    </section>

    {/* ── 2 · Sites directory ─────────────────────────────────────────── */}
    <section class="block" id="sites">
      <header class="block-h">
        <h2>Sites</h2>
      </header>
      <ul class="sites-grid">
        {SITES.map((s) => (
          <li>
            <a class="site-card" href={s.url}>
              <span class="site-name">{s.name}</span>
              <span class="site-desc">{s.desc}</span>
              <span class="site-open">Open &nearr;</span>
            </a>
          </li>
        ))}
      </ul>
    </section>

    {/* ── 3 · API fleet ───────────────────────────────────────────────── */}
    <section class="block" id="apis">
      <header class="block-h">
        <h2>API fleet</h2>
        <span class="block-count">16 endpoints</span>
      </header>
      <ul class="api-grid">
        {APIS.map((a) => (
          <li>
            <a class="api-card" href={`https://${a.host}`}>
              <span class="api-slug">{a.slug}</span>
              <span class="api-host">{a.host}</span>
              <span class="api-desc">{a.desc}</span>
            </a>
          </li>
        ))}
      </ul>
    </section>

    {/* ── 4 · Packages ────────────────────────────────────────────────── */}
    <section class="block" id="packages">
      <header class="block-h">
        <h2>npm packages</h2>
        <span class="block-count">@chirag127 &middot; 17 packages</span>
      </header>
      <ul class="pkg-grid">
        {PACKAGES.map((p) => (
          <li>
            <a class="pkg-card" href={`https://npm.im/@chirag127/${p.slug}`}>
              <span class="pkg-name">@chirag127/{p.slug}</span>
              <span class="pkg-site">{p.pkgSite}</span>
            </a>
          </li>
        ))}
      </ul>
    </section>

  </article>
</BaseLayout>

<style>
  /* ── Layout ──────────────────────────────────────────────────────── */
  .hub {
    padding-block: clamp(2rem, 6vw, 4rem) clamp(3rem, 8vw, 6rem);
  }

  /* ── 1 · Hero ────────────────────────────────────────────────────── */
  .hero {
    padding-block: clamp(3rem, 10vw, 6rem) clamp(2.5rem, 7vw, 4rem);
    border-bottom: 1px solid var(--md-outline-variant);
    margin-bottom: clamp(2.5rem, 6vw, 4rem);
  }
  .hero-inner {
    max-width: 44rem;
  }
  .hero-eyebrow {
    font-family: var(--md-font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--md-primary);
    margin: 0 0 0.75rem;
  }
  .hero-name {
    font-family: var(--md-font-display);
    font-size: clamp(2.75rem, 8vw, 5rem);
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.025em;
    color: var(--md-on-surface);
    margin: 0 0 0.5rem;
  }
  .hero-role {
    font-family: var(--md-font-body);
    font-size: clamp(1rem, 2.5vw, 1.25rem);
    color: var(--md-on-surface-variant);
    margin: 0 0 clamp(1.5rem, 4vw, 2rem);
  }

  /* Stats chips */
  .hero-stats {
    list-style: none;
    padding: 0;
    margin: 0 0 clamp(1.75rem, 4vw, 2.5rem);
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem;
  }
  .stat-chip {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.125rem;
    padding: 0.625rem 1.125rem;
    background: var(--md-surface-container-high);
    border-radius: var(--md-shape-lg);
    min-width: 5rem;
  }
  .stat-n {
    font-family: var(--md-font-display);
    font-size: 1.375rem;
    font-weight: 700;
    color: var(--md-primary);
    line-height: 1;
  }
  .stat-l {
    font-family: var(--md-font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--md-on-surface-variant);
  }

  /* CTA buttons */
  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .cta-primary {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 1.5rem;
    background: var(--md-primary);
    color: var(--md-on-primary);
    border-radius: var(--md-shape-full);
    font-family: var(--md-font-body);
    font-weight: 500;
    font-size: 0.9375rem;
    text-decoration: none;
    transition: opacity 0.15s;
  }
  .cta-primary:hover {
    opacity: 0.88;
    text-decoration: none;
  }
  .cta-secondary {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 1.5rem;
    background: transparent;
    color: var(--md-primary);
    border: 1px solid var(--md-outline-variant);
    border-radius: var(--md-shape-full);
    font-family: var(--md-font-body);
    font-weight: 500;
    font-size: 0.9375rem;
    text-decoration: none;
    transition: background 0.15s, border-color 0.15s;
  }
  .cta-secondary:hover {
    background: var(--md-surface-container-high);
    border-color: var(--md-primary);
    text-decoration: none;
  }

  /* ── Section scaffold ────────────────────────────────────────────── */
  .block {
    margin-block: clamp(2.5rem, 6vw, 4rem);
  }
  .block-h {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin: 0 0 clamp(1rem, 2.5vw, 1.5rem);
    padding-bottom: 0.625rem;
    border-bottom: 1px solid var(--md-outline-variant);
  }
  .block-h h2 {
    font-family: var(--md-font-display);
    font-size: clamp(1.375rem, 3vw, 1.875rem);
    font-weight: 600;
    margin: 0;
    color: var(--md-on-surface);
    letter-spacing: -0.015em;
  }
  .block-count {
    font-family: var(--md-font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--md-on-surface-variant);
    white-space: nowrap;
  }

  /* ── 2 · Sites grid ──────────────────────────────────────────────── */
  .sites-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 0.75rem;
  }
  .site-card {
    display: grid;
    grid-template-rows: auto 1fr auto;
    gap: 0.375rem;
    padding: 1.125rem 1.25rem;
    background: var(--md-surface-container-high);
    border-radius: var(--md-shape-lg);
    text-decoration: none;
    transition: background 0.15s, transform 0.15s;
  }
  .site-card:hover {
    background: var(--md-surface-container-highest);
    transform: translateY(-2px);
    text-decoration: none;
  }
  .site-name {
    font-family: var(--md-font-body);
    font-weight: 600;
    font-size: 0.9375rem;
    color: var(--md-primary);
    word-break: break-all;
  }
  .site-desc {
    font-family: var(--md-font-body);
    font-size: 0.875rem;
    line-height: 1.5;
    color: var(--md-on-surface-variant);
  }
  .site-open {
    font-family: var(--md-font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--md-primary);
    margin-top: 0.25rem;
  }

  /* ── 3 · API grid ────────────────────────────────────────────────── */
  .api-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 0.75rem;
  }
  .api-card {
    display: grid;
    grid-template-rows: auto auto 1fr;
    gap: 0.25rem;
    padding: 1rem 1.125rem;
    background: var(--md-surface-container);
    border-radius: var(--md-shape-md);
    border: 1px solid var(--md-outline-variant);
    text-decoration: none;
    transition: border-color 0.15s, background 0.15s;
  }
  .api-card:hover {
    border-color: var(--md-primary);
    background: var(--md-surface-container-high);
    text-decoration: none;
  }
  .api-slug {
    font-family: var(--md-font-display);
    font-weight: 600;
    font-size: 1rem;
    color: var(--md-on-surface);
  }
  .api-host {
    font-family: var(--md-font-mono);
    font-size: 0.6875rem;
    color: var(--md-primary);
    letter-spacing: 0.02em;
  }
  .api-desc {
    font-family: var(--md-font-body);
    font-size: 0.8125rem;
    line-height: 1.45;
    color: var(--md-on-surface-variant);
    margin-top: 0.375rem;
  }

  /* ── 4 · Packages grid ───────────────────────────────────────────── */
  .pkg-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 0.625rem;
  }
  .pkg-card {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 0.875rem 1rem;
    background: var(--md-surface-container);
    border-radius: var(--md-shape-md);
    text-decoration: none;
    transition: background 0.15s;
  }
  .pkg-card:hover {
    background: var(--md-surface-container-high);
    text-decoration: none;
  }
  .pkg-name {
    font-family: var(--md-font-mono);
    font-size: 0.8125rem;
    color: var(--md-on-surface);
    font-weight: 500;
  }
  .pkg-site {
    font-family: var(--md-font-mono);
    font-size: 0.625rem;
    color: var(--md-primary);
    letter-spacing: 0.02em;
  }

  /* ── Responsive ──────────────────────────────────────────────────── */
  @media (max-width: 600px) {
    .hero-stats {
      gap: 0.5rem;
    }
    .stat-chip {
      padding: 0.5rem 0.875rem;
      min-width: 4rem;
    }
    .api-grid,
    .pkg-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 400px) {
    .api-grid,
    .pkg-grid {
      grid-template-columns: 1fr;
    }
    .hero-ctas {
      flex-direction: column;
    }
  }
</style>
