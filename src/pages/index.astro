---
/*
 * Oriz / home — index page (Alphabet-style parent-company landing).
 *
 * Modeled after https://abc.xyz — pure white background, single ~720px
 * centered column, serif everywhere, no header/footer chrome, plain rows
 * of subsidiary sites. The CONTENT, however, has been expanded so a
 * recruiter / collaborator landing here for the first time forms an
 * accurate picture of the depth of work behind the family in <5 seconds.
 *
 * Bands on the page (top → bottom):
 *   1. Wordmark (`Oriz`) — large serif, top-left. Title-Case per
 *      `knowledge/decisions/branding/title-case-oriz.md`.
 *   2. One-paragraph hero — what Oriz is + who built it.
 *   3. Sites — the 10 family sites (this page itself excluded).
 *   4. Browser extensions — auto-fed from GitHub API at build, filtered
 *      by `*-ext` / `*-vsc-ext` slug suffix per the family naming rule.
 *      Falls back to a placeholder line when none have shipped yet.
 *   5. Open-source packages — auto-fed from GitHub API. Hardcoded
 *      fallback list is currently empty (in-flight).
 *   6. Tech stack — condensed 15-row digest of the canonical stack
 *      table at `knowledge/services/index.md`. Three columns: Layer,
 *      Pick, Why. No decoration.
 *   7. By the numbers — small metric strip (repos, concept files,
 *      sites, languages, years building). Build-time fetched where
 *      possible, hardcoded fallback otherwise.
 *   8. Latest from the blog — 5 most recent posts pulled from
 *      `https://blog.oriz.in/rss.xml` at build time. Graceful fallback
 *      if the feed is missing (the blog may not be deployed yet).
 *   9. Recent commits — top 5 PushEvents from chirag127's public
 *      activity feed. Graceful fallback if rate-limited.
 *  10. More — GitHub, Support, Privacy, Search the web (MultiSearch).
 *  11. StatusBanner — invisible unless an incident is live.
 *  12. Tiny colophon line — keeps "small + plain" rule.
 *
 * BaseLayout is invoked with chrome="bare" (no Header / no Footer) and a
 * body class of "home-bare" which flips the global tokens to
 * white-paper / near-black-ink / serif-everywhere (see global.css).
 *
 * IMPLEMENTATION NOTE — every build-time API fetch is wrapped in
 * try/catch with hardcoded fallbacks. An offline build, a 60-req/h
 * GitHub-anonymous rate limit, or a transient DNS hiccup MUST NOT break
 * the production build. Astro's static build re-runs hourly via the CI
 * cron, so the data freshens without any client-side fetch cost.
 */
import BaseLayout from '~/layouts/BaseLayout.astro'
import MultiSearch from '@chirag127/astro-chrome/MultiSearch'
import StatusBanner from '@chirag127/astro-chrome/StatusBanner'

import Parser from 'rss-parser'

/* ────────────────────────────────────────────────────────────────────
 * Sites — the 10 sister-site rows.
 * Order matches the family directory; oriz-urls-to-md is intentionally
 * an empty placeholder (see decisions/branding/oriz-urls-to-md-site-empty-placeholder.md).
 * The current `home` slug is excluded (this IS the home page).
 * ──────────────────────────────────────────────────────────────────── */
const SITES: { name: string; desc: string; domain: string; url: string }[] = [
  { name: 'Blog',        desc: 'Long-form essays + tutorials.',     domain: 'blog.oriz.in',        url: 'https://blog.oriz.in' },
  { name: 'Books',       desc: 'Reading log + book reviews.',       domain: 'books.oriz.in',       url: 'https://books.oriz.in' },
  { name: 'Book Lore',   desc: 'Knowledge graph from books.',       domain: 'book-lore.oriz.in',   url: 'https://book-lore.oriz.in' },
  { name: 'Cards',       desc: 'Spaced-repetition flashcards.',     domain: 'cards.oriz.in',       url: 'https://cards.oriz.in' },
  { name: 'Finance',     desc: 'Personal finance dashboard.',       domain: 'finance.oriz.in',     url: 'https://finance.oriz.in' },
  { name: 'Image Tools', desc: 'Browser image utilities.',          domain: 'image-tools.oriz.in', url: 'https://image-tools.oriz.in' },
  { name: 'Journal',     desc: 'Daily journal.',                    domain: 'journal.oriz.in',     url: 'https://journal.oriz.in' },
  { name: 'Me',          desc: 'Lifestream.',                       domain: 'me.oriz.in',          url: 'https://me.oriz.in' },
  { name: 'PDF Tools',   desc: 'Browser PDF utilities.',            domain: 'pdf-tools.oriz.in',   url: 'https://pdf-tools.oriz.in' },
  { name: 'URLs to MD',  desc: 'URL → clean Markdown.',             domain: 'urls-to-md.oriz.in',  url: 'https://urls-to-md.oriz.in' },
]

/* ────────────────────────────────────────────────────────────────────
 * Build-time GitHub API helper — anonymous, gracefully tolerant.
 * ──────────────────────────────────────────────────────────────────── */
interface GhRepo {
  name: string
  description: string | null
  html_url: string
  archived?: boolean
  fork?: boolean
}
interface GhEvent {
  type: string
  repo: { name: string }
  payload: { commits?: { message: string }[] }
  created_at: string
}

async function ghFetch<T>(url: string): Promise<T | null> {
  try {
    const res = await fetch(url, {
      headers: {
        Accept: 'application/vnd.github+json',
        'User-Agent': 'oriz-home-build',
      },
    })
    if (!res.ok) return null
    return (await res.json()) as T
  } catch {
    return null
  }
}

/* ────────────────────────────────────────────────────────────────────
 * Extensions — repos whose slug ends in `-ext` or `-vsc-ext`.
 * Hardcoded fallback list is empty today (no extensions shipped yet);
 * this auto-fills as soon as the first extension repo lands on GitHub.
 * ──────────────────────────────────────────────────────────────────── */
interface ExtRow { name: string; desc: string; url: string }

let extensions: ExtRow[] = []
let extsFromApi = false
{
  const repos = await ghFetch<GhRepo[]>(
    'https://api.github.com/users/chirag127/repos?per_page=100&sort=updated',
  )
  if (Array.isArray(repos)) {
    extensions = repos
      .filter((r) => !r.archived && !r.fork)
      .filter((r) => /-(?:vsc-)?ext$/.test(r.name))
      .map((r) => ({
        name: r.name,
        desc: r.description ?? '',
        url: r.html_url,
      }))
    extsFromApi = true
  }
}

/* ────────────────────────────────────────────────────────────────────
 * Open-source packages — start with the hardcoded family list (matches
 * `packages/` submodules in master `.gitmodules`), then OPT-IN augment
 * with anything else from the GitHub API that looks package-shaped.
 * Hardcoded list is the source of truth so an API miss still produces
 * a complete page.
 * ──────────────────────────────────────────────────────────────────── */
interface PkgRow {
  name: string         // npm-scoped name shown in-page
  desc: string
  npm: string          // npmjs.com URL
  github: string       // github.com URL
}

const PKGS: PkgRow[] = []

/* ────────────────────────────────────────────────────────────────────
 * Tech stack — condensed 15-row table.
 * Source: knowledge/services/index.md. Rows are intentionally short;
 * the canonical knowledge bundle is the deep-dive surface.
 * ──────────────────────────────────────────────────────────────────── */
const STACK: { layer: string; pick: string; why: string }[] = [
  { layer: 'Hosting',      pick: 'Cloudflare Pages',                                                          why: 'Free unlimited, edge CDN.' },
  { layer: 'Edge compute', pick: 'Cloudflare Workers',                                                        why: '100K req/day free.' },
  { layer: 'Auth',         pick: 'Firebase Auth (Spark)',                                                     why: 'Free unlimited.' },
  { layer: 'Database',     pick: 'Firestore + Turso libSQL + Neon Postgres + JSONL canonical',                why: '4-tier strategy.' },
  { layer: 'AI',           pick: 'Puter.js (browser) + Cloudflare Workers AI (server)',                       why: 'Free, no API keys.' },
  { layer: 'Search',       pick: 'Algolia + Pagefind',                                                        why: 'Free 1M docs.' },
  { layer: 'Analytics',    pick: 'CF Web Analytics + GA4 + PostHog + Microsoft Clarity + UTM',                why: '5-tier, all free.' },
  { layer: 'Errors',       pick: 'Sentry',                                                                    why: 'Free 5K events/mo, env toggle.' },
  { layer: 'Email',        pick: 'Resend (transactional) + EmailOctopus (marketing) + Buttondown (digest)',  why: 'All free.' },
  { layer: 'Push',         pick: 'Firebase Cloud Messaging + Knock',                                          why: 'Free unlimited + 10K/mo.' },
  { layer: 'Billing',      pick: 'Razorpay (India) + Lemon Squeezy (intl) + 10 donation rails',               why: 'Free, no card.' },
  { layer: 'CMS',          pick: 'Markdown in Git',                                                           why: 'Zero infra.' },
  { layer: 'Build',        pick: 'Astro 6 + React 19 + pnpm + GitHub Actions',                                why: 'OSS.' },
  { layer: 'Code quality', pick: 'Sonarcloud + CodeRabbit + Codecov + CodeClimate + DeepSource + biome + Tokei', why: '9-tool stack.' },
  { layer: 'Knowledge',    pick: 'OKF v0.1 bundle in `knowledge/`',                                           why: '200+ concept files.' },
]

/* ────────────────────────────────────────────────────────────────────
 * By-the-numbers — auto-tracked metric strip.
 * Repo count comes from the GitHub API; concept count is hardcoded
 * (the build container doesn't necessarily mount the parent monorepo's
 * knowledge/ tree). Years-building is brand-locked at 2 years.
 * ──────────────────────────────────────────────────────────────────── */
let repoCount = 60 // fallback
{
  const userMeta = await ghFetch<{ public_repos: number }>('https://api.github.com/users/chirag127')
  if (userMeta && typeof userMeta.public_repos === 'number') {
    repoCount = userMeta.public_repos
  }
}

const NUMBERS: { label: string; value: string }[] = [
  { label: 'Public repos',                value: String(repoCount) },
  { label: 'Concept files in knowledge',  value: '430+' },
  { label: 'Sites in family',             value: '10' },
  { label: 'Languages',                   value: 'TypeScript · Astro · React · MDX' },
  { label: 'Years building',              value: '2 (since 2024)' },
]

/* ────────────────────────────────────────────────────────────────────
 * Latest 5 posts from the blog feed. Build-time fetch via rss-parser.
 * The blog site may not be deployed yet — wrap in try/catch and degrade
 * gracefully ("Blog launching soon — see github…"). Never let an RSS
 * failure break the build.
 * ──────────────────────────────────────────────────────────────────── */
interface Post {
  title: string
  link: string
  pubDate: string
}

let posts: Post[] = []
let blogFetchOk = false
try {
  const parser = new Parser({ timeout: 8000 })
  const feed = await parser.parseURL('https://blog.oriz.in/rss.xml')
  posts = (feed.items ?? []).slice(0, 5).map((i) => ({
    title: i.title ?? '(untitled)',
    link: i.link ?? 'https://blog.oriz.in',
    pubDate: i.pubDate ?? i.isoDate ?? '',
  }))
  blogFetchOk = posts.length > 0
} catch {
  posts = []
  blogFetchOk = false
}

/* ────────────────────────────────────────────────────────────────────
 * Recent commits — fold the user's public PushEvents into a 5-row
 * "what's been shipped lately" strip. Fail silently on rate-limit.
 * ──────────────────────────────────────────────────────────────────── */
interface CommitRow { repo: string; message: string; ago: string; url: string }

let commits: CommitRow[] = []
{
  const events = await ghFetch<GhEvent[]>(
    'https://api.github.com/users/chirag127/events/public?per_page=30',
  )
  if (Array.isArray(events)) {
    commits = events
      .filter((e) => e.type === 'PushEvent' && Array.isArray(e.payload?.commits))
      .flatMap((e) => {
        const top = (e.payload.commits ?? [])[0]
        if (!top) return []
        const shortRepo = e.repo.name.replace(/^chirag127\//, '')
        return [{
          repo: shortRepo,
          message: top.message.split('\n')[0],
          ago: relativeTime(e.created_at),
          url: `https://github.com/${e.repo.name}`,
        }]
      })
      .slice(0, 5)
  }
}

function relativeTime(iso: string): string {
  const then = new Date(iso).getTime()
  if (Number.isNaN(then)) return ''
  const sec = Math.max(0, (Date.now() - then) / 1000)
  if (sec < 60) return `${Math.floor(sec)}s ago`
  if (sec < 3600) return `${Math.floor(sec / 60)}m ago`
  if (sec < 86400) return `${Math.floor(sec / 3600)}h ago`
  if (sec < 86400 * 30) return `${Math.floor(sec / 86400)}d ago`
  return new Date(iso).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: '2-digit' })
}

function fmtDate(iso: string): string {
  if (!iso) return ''
  const d = new Date(iso)
  if (Number.isNaN(d.getTime())) return ''
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: '2-digit' })
}

const buildDate = new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: '2-digit' })
---

<BaseLayout
  chrome="bare"
  bodyClass="home-bare"
  title="Oriz — a family of free-forever, recruiter-grade web tools"
  description="Oriz is a family of free-forever, recruiter-grade web tools, reading sites, and developer libraries built and maintained by Chirag Singhal. Every site shares one sign-in, one design system, and one knowledge base."
>
  {/* Status banner — renders nothing unless an active incident is live. */}
  <div class="status-mount"><StatusBanner client:load siteId="home" /></div>

  <article class="page">
    {/* 1 — Wordmark. Plain text serif, no decoration. Title-Case lock. */}
    <h1 class="brand">Oriz</h1>

    {/* 2 — Hero paragraph. */}
    <p class="lede">
      Oriz — a 17-package, 26-app open family by{' '}
      <a class="lede-link" href="https://me.oriz.in">Chirag Singhal</a>. Free-forever,
      recruiter-grade web tools, reading sites, and developer libraries. Every site
      shares one sign-in, one design system, and one knowledge base.
    </p>

    {/* 2a — 5-section family grid (2026-06-22). Five primary entry points. */}
    <h2 class="section-h">Explore the family</h2>
    <ul class="family-grid">
      <li class="family-cell"><a href="/apps/"><strong>Apps</strong><span>26 web apps across tools, content, personal &amp; hub.</span></a></li>
      <li class="family-cell"><a href="/tools/"><strong>Tools</strong><span>16 focused utilities — PDF, finance, dev, health.</span></a></li>
      <li class="family-cell"><a href="/books/"><strong>Books</strong><span>5 books on Stack, Paisa, PDF, Janaushdhi, Me.</span></a></li>
      <li class="family-cell"><a href="https://packages.oriz.in"><strong>Packages</strong><span>17 npm packages powering the family.</span></a></li>
      <li class="family-cell"><a href="https://me.oriz.in"><strong>Me</strong><span>Chirag Singhal — lifestream &amp; resume.</span></a></li>
    </ul>

    {/* 2b — Section nav. Plain text links to /apps, /packages, /mobile,
            /desktop, /extensions. The five new sections (2026-06-21). */}
    <nav class="section-nav" aria-label="Catalog sections">
      <a href="/apps/">Apps</a>
      <span aria-hidden="true">·</span>
      <a href="/packages/">Packages</a>
      <span aria-hidden="true">·</span>
      <a href="/mobile/">Mobile</a>
      <span aria-hidden="true">·</span>
      <a href="/desktop/">Desktop</a>
      <span aria-hidden="true">·</span>
      <a href="/extensions/">Extensions</a>
    </nav>

    {/* 3 — Sites list. Plain rows, no card chrome. */}
    <h2 class="section-h">Sites</h2>
    <ul class="sites">
      {
        SITES.map((s) => (
          <li class="site-row">
            <a class="site-link" href={s.url}>
              <strong class="site-name">{s.name}</strong>
              <span class="site-desc">{s.desc}</span>
              <span class="site-domain">{s.domain}</span>
            </a>
          </li>
        ))
      }
    </ul>

    {/* 4 — Browser extensions. Auto-filled from GH API; placeholder line until shipped. */}
    <h2 class="section-h">Browser extensions</h2>
    {
      extensions.length > 0 ? (
        <ul class="sites">
          {extensions.map((x) => (
            <li class="site-row">
              <a class="site-link" href={x.url}>
                <strong class="site-name">{x.name}</strong>
                <span class="site-desc">{x.desc}</span>
                <span class="site-domain">github</span>
              </a>
            </li>
          ))}
        </ul>
      ) : (
        <p class="post-fallback">
          Browser extensions in development — see{' '}
          <a href="https://github.com/chirag127?tab=repositories&q=oriz+ext">github.com/chirag127</a>.
          {extsFromApi ? '' : ' (List auto-fills at next build.)'}
        </p>
      )
    }

    {/* 5 — Open-source packages. Empty by default; will refill as packages publish. */}
    <h2 class="section-h">Open-source packages</h2>
    {
      PKGS.length > 0 ? (
        <ul class="sites">
          {PKGS.map((p) => (
            <li class="site-row">
              <div class="pkg-link">
                <strong class="site-name">{p.name}</strong>
                <span class="site-desc">{p.desc}</span>
                <span class="site-domain">
                  <a href={p.npm}>npm</a> · <a href={p.github}>github</a>
                </span>
              </div>
            </li>
          ))}
        </ul>
      ) : (
        <p class="post-fallback">
          Packages in development — see{' '}
          <a href="https://github.com/chirag127?tab=repositories">github.com/chirag127</a>.
        </p>
      )
    }

    {/* 6 — Tech stack. 3-column plain table. */}
    <h2 class="section-h">Tech stack</h2>
    <table class="stack">
      <thead>
        <tr>
          <th scope="col">Layer</th>
          <th scope="col">Pick</th>
          <th scope="col">Why</th>
        </tr>
      </thead>
      <tbody>
        {
          STACK.map((row) => (
            <tr>
              <td class="stack-layer">{row.layer}</td>
              <td class="stack-pick">{row.pick}</td>
              <td class="stack-why">{row.why}</td>
            </tr>
          ))
        }
      </tbody>
    </table>

    {/* 7 — By the numbers. */}
    <h2 class="section-h">By the numbers</h2>
    <ul class="more">
      {
        NUMBERS.map((n) => (
          <li>
            <span class="more-name">{n.label}</span>
            <span>{n.value}</span>
          </li>
        ))
      }
    </ul>

    {/* 8 — Latest from the blog. Build-time RSS, graceful fallback. */}
    <h2 class="section-h">Latest from the blog</h2>
    {
      blogFetchOk ? (
        <ul class="posts">
          {posts.map((p) => (
            <li class="post-row">
              <span class="post-date">{fmtDate(p.pubDate)}</span>
              <span class="post-sep" aria-hidden="true">·</span>
              <a class="post-link" href={p.link}>
                {p.title}
              </a>
            </li>
          ))}
        </ul>
      ) : (
        <p class="post-fallback">
          Blog launching soon — see{' '}
          <a href="https://github.com/chirag127/oriz-blog-site">github.com/chirag127/oriz-blog-site</a>.
        </p>
      )
    }

    {/* 9 — Recent commits. */}
    <h2 class="section-h">Recent commits</h2>
    {
      commits.length > 0 ? (
        <ul class="posts">
          {commits.map((c) => (
            <li class="post-row">
              <span class="post-date">{c.ago}</span>
              <span class="post-sep" aria-hidden="true">·</span>
              <a class="post-link" href={c.url}>
                <strong>{c.repo}</strong> — {c.message}
              </a>
            </li>
          ))}
        </ul>
      ) : (
        <p class="post-fallback">
          Activity feed unavailable right now — see{' '}
          <a href="https://github.com/chirag127">github.com/chirag127</a>.
        </p>
      )
    }

    {/* 10 — More. Plain links, including the MultiSearch popover. */}
    <h2 class="section-h">More</h2>
    <ul class="more">
      <li>
        <span class="more-name">GitHub</span>
        <a href="https://github.com/chirag127/oriz">github.com/chirag127/oriz</a>
      </li>
      <li>
        <span class="more-name">Support</span>
        <a href="/support/">/support</a>
      </li>
      <li>
        <span class="more-name">Privacy</span>
        <a href="/privacy/">/privacy</a>
      </li>
      <li>
        <span class="more-name">Search the web</span>
        <span class="search-mount">
          <MultiSearch client:idle titleSuffix=" — Oriz" label="Search the web →" />
        </span>
      </li>
    </ul>

    {/* 12 — Tiny colophon. */}
    <p class="colophon">
      Built by Chirag Singhal · <a href="https://github.com/chirag127/oriz">Source on GitHub</a> ·
      Last deployed {buildDate}
    </p>
  </article>
</BaseLayout>

<style>
  /* ── Page scaffold ──────────────────────────────────────────────────── */

  .status-mount {
    /* Status banner is dismissible / hidden by default — keep it pinned to
       the top so it doesn't displace the page above the fold normally. */
    width: 100%;
  }

  .page {
    max-width: 720px;
    margin: 0 auto;
    padding: clamp(2rem, 6vw, 4rem) clamp(1.25rem, 4vw, 2rem)
      clamp(3rem, 8vw, 5rem);
  }

  /* ── 1 · Wordmark ──────────────────────────────────────────────────── */

  .brand {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(2.5rem, 6vw, 3.25rem);
    letter-spacing: -0.01em;
    line-height: 1;
    margin: 0 0 clamp(1.5rem, 4vw, 2.25rem);
    color: var(--ink);
  }

  /* ── 2 · Hero paragraph ────────────────────────────────────────────── */

  .lede {
    font-family: var(--font-display);
    font-size: 1.0625rem;
    line-height: 1.65;
    margin: 0 0 clamp(2.25rem, 6vw, 3.25rem);
    color: var(--ink);
    max-width: 60ch;
  }
  .lede-link {
    color: var(--accent);
  }

  /* ── 2b · Section nav row ─────────────────────────────────────────── */

  .section-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: baseline;
    margin: 0 0 clamp(2.25rem, 6vw, 3.25rem);
    font-family: var(--font-display);
    font-size: 1rem;
    color: var(--ink-mute);
  }
  .section-nav a {
    color: var(--accent);
  }
  .section-nav a:hover,
  .section-nav a:focus-visible {
    text-decoration: underline;
  }

  /* ── Section headings — small caps, regular weight ─────────────────── */

  .section-h {
    font-family: var(--font-display);
    font-variant-caps: all-small-caps;
    font-feature-settings: 'smcp' 1, 'c2sc' 1;
    font-weight: 500;
    font-size: 0.9375rem;
    letter-spacing: 0.08em;
    color: var(--ink-mute);
    margin: clamp(2rem, 5vw, 2.75rem) 0 clamp(0.75rem, 2vw, 1rem);
  }

  /* ── 3-5 · Plain row lists (sites / extensions / packages) ─────────── */

  .sites,
  .posts,
  .more {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .site-row {
    border-top: 1px solid var(--rule);
  }
  .site-row:last-child {
    border-bottom: 1px solid var(--rule);
  }

  .site-link,
  .pkg-link {
    display: grid;
    grid-template-columns: 7.5rem 1fr auto;
    gap: 1rem;
    align-items: baseline;
    padding-block: 0.625rem;
    color: inherit;
    text-decoration: none;
  }
  .site-link:hover {
    text-decoration: none;
  }
  .site-link:hover .site-name,
  .site-link:hover .site-domain {
    color: var(--accent);
  }
  .site-link:hover .site-domain {
    text-decoration: underline;
  }

  .site-name {
    font-family: var(--font-display);
    font-weight: 600;
    color: var(--ink);
  }
  .site-desc {
    font-family: var(--font-display);
    font-weight: 400;
    color: var(--ink);
  }
  .site-domain {
    font-family: var(--font-display);
    font-size: 0.9375rem;
    color: var(--ink-mute);
    text-align: right;
    white-space: nowrap;
  }
  .pkg-link .site-domain a {
    color: var(--accent);
  }

  /* ── 6 · Tech-stack table ─────────────────────────────────────────── */

  .stack {
