---
import Pricing from '@chirag127/astro-billing/Pricing.astro'
/*
 * /pricing — THE canonical pricing surface for the entire oriz family.
 *
 * User mandate (2026-06-22): payments only on oriz.in. Razorpay
 * approved this single domain as the business website, so every
 * other app's "Upgrade" link redirects here (see `pricingUrl()` in
 * @chirag127/astro-shell).
 *
 * The 3-tier table + monthly/yearly toggle + Razorpay Checkout JS
 * islands all live in <Pricing /> from @chirag127/astro-billing.
 * This page is purely a mount point.
 */
import BaseLayout from '~/layouts/BaseLayout.astro'
---

<BaseLayout
  title="Pricing — Oriz"
  description="Free forever, with optional Pro (₹99/mo) and Max (₹299/mo) tiers. Pay once, unlocks every app in the family."
  wordmarkSubtitle="pricing"
  sidebar={false}
>
  <article class="page spine">
    <h1 class="page-title">Pricing</h1>
    <p class="page-lede">
      Every app and every package in the Oriz family stays free. Pro and Max are optional —
      one subscription unlocks Pro features across <a href="/apps/">all apps</a>,
      removes ads, and funds maintenance.
    </p>

    <Pricing />

    <p class="note">
      Questions about billing? See <a href="/refunds/">refunds</a> and <a href="/terms/">terms</a>.
      All transactions on this page are processed by Razorpay on <code>oriz.in</code>.
    </p>
  </article>
</BaseLayout>

<style>
  .page {
    max-width: 1100px;
    margin: 0 auto;
    padding: clamp(1.5rem, 4vw, 3rem) clamp(1rem, 3vw, 2rem);
  }
  .page-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 2.75rem);
    margin: 0 0 0.75rem;
    color: var(--ink);
  }
  .page-lede {
    font-family: var(--font-display);
    font-size: 1.0625rem;
    line-height: 1.6;
    color: var(--ink);
    max-width: 60ch;
    margin: 0 0 2rem;
  }
  .note {
    margin-top: 2rem;
    color: var(--ink-mute);
    font-size: 0.9375rem;
  }
  .note code {
    background: var(--rule);
    padding: 0.125rem 0.375rem;
    border-radius: 3px;
  }
</style>
