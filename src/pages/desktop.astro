---
import AppCard from '~/components/AppCard.astro'
import type { Channel } from '~/data/apps'
import { APPS } from '~/data/apps'
/*
 * /desktop — Windows / macOS / Linux distribution channels per app.
 *
 * For each oriz app, we render an AppCard with four channel badges:
 *   - Microsoft Store      (ms_store)
 *   - MSIX direct          (github_release_msix — auto-discovered)
 *   - macOS .dmg           (github_release_dmg — auto-discovered)
 *   - Linux .AppImage      (github_release_appimage — auto-discovered)
 *
 * Apps with no desktop channels filled in show 'Coming soon — Windows /
 * macOS / Linux via PWABuilder' badges. Per
 * knowledge/decisions/architecture/pwabuilder-as-primary-converter.md
 * PWABuilder generates MSIX (Windows), Mac (.pkg / .dmg), and Linux
 * (snap / AppImage) packages from each app's PWA.
 */
import BaseLayout from '~/layouts/BaseLayout.astro'

const DESKTOP_CHANNELS: Channel[] = [
  'ms_store',
  'github_release_msix',
  'github_release_dmg',
  'github_release_appimage',
]

const apps = APPS.filter((a) => a.category !== 'hub' && a.category !== 'personal')
---

<BaseLayout
  title="Desktop — oriz"
  description="Windows, macOS, and Linux distribution channels for every oriz app. Install from the Microsoft Store or download MSIX / DMG / AppImage directly."
  wordmarkSubtitle="desktop"
>
  <article class="page spine">
    <h1 class="page-title">Desktop</h1>
    <p class="page-lede">
      Desktop distribution for every oriz app — Windows via the Microsoft Store
      or MSIX, macOS via .dmg, Linux via AppImage. Direct-download URLs are
      pulled from GitHub Releases at build time.
    </p>

    <p class="page-note">
      Most apps are <em>coming soon</em> — desktop packages are generated by
      <a href="https://www.pwabuilder.com/">PWABuilder</a> from each app's PWA,
      then submitted to the Microsoft Store and shipped as GitHub Releases.
      Until then, install the PWA directly from each app's subdomain.
    </p>

    <section class="app-section">
      <div class="app-grid">
        {apps.map((app) => <AppCard app={app} channels={DESKTOP_CHANNELS} />)}
      </div>
    </section>
  </article>
</BaseLayout>

<style>
  .page {
    padding-block: clamp(2rem, 5vw, 3rem) clamp(3rem, 6vw, 4rem);
  }
  .page-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(2rem, 5vw, 2.75rem);
    margin: 0 0 0.5rem;
    color: var(--ink);
  }
  .page-lede,
  .page-note {
    font-family: var(--font-display);
    font-size: 1.0625rem;
    color: var(--ink);
    max-width: 60ch;
    margin: 0 0 1rem;
  }
  .page-note {
    color: var(--ink-mute);
    border-left: 2px solid var(--rule);
    padding-left: 0.75rem;
    margin-bottom: 2rem;
  }
  .app-section {
    margin-top: 1.5rem;
  }
  .app-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }
</style>
